{
  "name": "MAX7219 Digital Clock",
  "version": "1.0.0",
  "slug": "MAX7219_Digital_Clock",
  "description": "MAX7219 LED Matrix via Raspberry Pi GPIO",
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "arch": ["armv7", "aarch64"],
