{
  "name": "MAX7219 Display Engine",
  "version": "2.6.2",
  "slug": "max7219_clock",
  "description": "Production-ready MAX7219 display engine with MQTT, effects, scheduler and Ingress UI",
  "arch": ["aarch64", "armv7", "armhf"],
  "startup": "services",
  "boot": "auto",
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:led-strip-variant",
  "panel_title": "MAX7219",
  "init": false,
  "services": ["mqtt:want"],
  "privileged": ["SYS_RAWIO"],
  "devices": ["/dev/spidev0.0", "/dev/spidev0.1"],
  "ports": {
    "8099/tcp": null
  },
  "ports_description": {
    "8099/tcp": "Web UI port (make empty to disable; Ingress remains available)"
  },
  "options": {
    "mqtt": {
      "host": "core-mosquitto",
      "port": 1883,
      "auto": true,
      "discovery": true,
      "discovery_prefix": "homeassistant",
      "reconnect_min_delay": 1,
      "reconnect_max_delay": 8,
      "initial_retry_delay": 0.5,
      "retry_max_delay": 5.0,
      "username": "",
      "password": "",
      "namespace": "mirarus/max7219"
    },
    "telemetry": {
      "enabled": true,
      "interval": 15
    },
    "github": {
      "version_check": true,
      "repo": "mirarus/ha-addons",
      "check_timeout": 3
    },  
    "default_text": "HELLO",
    "default_mode": "text",
    "default_effect": "static",
    "brightness": 5,
    "speed": 0.15,
    "cascaded": 4,
    "spi_port": 0,
    "spi_device": 0,
    "block_orientation": 90,
    "rotate": 0
  },
  "schema": {
    "mqtt": {
      "host": "str",
      "port": "port",
      "auto": "bool",
      "discovery": "bool",
      "discovery_prefix": "str",
      "reconnect_min_delay": "int(1,30)",
      "reconnect_max_delay": "int(1,120)",
      "initial_retry_delay": "float(0.2,10)",
      "retry_max_delay": "float(1,60)",
      "username": "str?",
      "password": "password?",
      "namespace": "str"
    },
    "telemetry": {
      "enabled": "bool",
      "interval": "int(5,300)"
    },
    "github": {
      "version_check": "bool",
      "repo": "str",
      "check_timeout": "int(1,15)"
    },
    "default_text": "str",
    "default_mode": "list(text|clock)",
    "default_effect": "list(static|scroll|marquee|blink|invert|wave)",
    "brightness": "int(0,255)",
    "speed": "float(0.02,5)",
    "cascaded": "int(1,16)",
    "spi_port": "int(0,1)",
    "spi_device": "int(0,1)",
    "block_orientation": "int(-360,360)",
    "rotate": "int(0,3)"
  }
}
